{
  "name": "emojico",
  "version": "0.0.11",
  "description": "CLI tool to convert emoji to favicon assets",
  "main": "dist/index.js",
  "bin": {
    "emojico": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/threepointone/emojico.git"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/index.js --external:@napi-rs/canvas --banner:js='#!/usr/bin/env node'",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "emoji",
    "favicon",
    "cli"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "author": "Sunil Pai <threepointone@gmail.com>",
  "license": "ISC",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.95"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/pngjs": "^6.0.5",
    "esbuild": "^0.27.3",
    "pngjs": "^7.0.0",
    "typescript": "^5.9.3",
    "unicode-emoji-json": "^0.8.0",
    "vitest": "^4.0.18"
  }
}
